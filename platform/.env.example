# ─── Database (PostgreSQL) ────────────────────────────────────────────────────
# Standard Postgres connection string. Works with Railway Postgres, Neon, Supabase, etc.
DATABASE_URL=postgresql://user:password@host:5432/companion?sslmode=require

# ─── Better Auth ──────────────────────────────────────────────────────────────
BETTER_AUTH_SECRET=your-session-secret-min-32-chars
BETTER_AUTH_URL=http://localhost:3458

# ─── Resend (transactional emails) ───────────────────────────────────────────
# When set, enables email verification on sign-up, password reset emails,
# and organization invitation emails via Resend.
# Without it, emails are logged to console (dev mode) and verification is skipped.
RESEND_API_KEY=re_...
# Optional — defaults to "Companion Cloud <noreply@thecompanion.sh>"
RESEND_FROM_EMAIL=Companion Cloud <noreply@thecompanion.sh>

# ─── Stripe ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# ─── Instance provisioning ──────────────────────────────────────────────────
# Recommended managed-runtime image that starts `the-companion serve`.
COMPANION_IMAGE=docker.io/stangirard/the-companion-server:latest

# ─── Hetzner Cloud (instance provisioning) ──────────────────────────────────
# Required
HETZNER_API_TOKEN=hcloud_...
# Optional Hetzner SSH key id/name to inject during server create
HETZNER_SSH_KEY_ID=
# Optional per-plan server type overrides
HETZNER_SERVER_TYPE_STARTER=cpx11
HETZNER_SERVER_TYPE_PRO=cpx21
HETZNER_SERVER_TYPE_ENTERPRISE=cpx31

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3458
